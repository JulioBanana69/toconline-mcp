{
  "version": 2,
  "builds": [
    {
      "src": "api/mcp.js",
      "use": "@vercel/node"
    }
  ],
  "routes": [
    {
      "src": "/mcp",
      "dest": "/api/mcp.js",
      "methods": [
        "GET",
        "POST",
        "DELETE"
      ]
    },
    {
      "src": "/(.*)",
      "dest": "/api/mcp.js"
    }
  ],
  "env": {
    "TOCONLINE_CLIENT_ID": "@toconline_client_id",
    "TOCONLINE_CLIENT_SECRET": "@toconline_client_secret"
  }
}